<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
  ROS2 Control tanımı — MOCK (Sahte) Hardware
  ============================================
  Serial port iletişimini nav2_motor_bridge.py yapıyor.
  Bu dosya sadece robot_state_publisher'ın URDF'yi kabul etmesi ve
  controller yapısının tanımlı olması için gerekli.
  
  ÖNEMLİ: my_robot_hardware/DiffDriveSystem KULLANILMIYOR!
  O plugin /dev/ttyAMA0'ı açmaya çalışıyor ve nav2_motor_bridge ile
  çakışarak encoder verisi kaybolmasına neden oluyordu.
  -->

  <xacro:macro name="my_robot_ros2_control" params="name prefix">
    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>mock_components/GenericSystem</plugin>
        <param name="fake_sensor_commands">false</param>
        <param name="state_following_offset">0.0</param>
      </hardware>
      <joint name="${prefix}left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${prefix}right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
  </xacro:macro>

</robot>
